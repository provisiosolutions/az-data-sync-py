{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync: Retrieve Latest Files",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "sync.py",
                "--config",
                "config.json"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}